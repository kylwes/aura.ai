+            if (this.mode === 'resize' && this.dragStarted) {
+                if (this.itemEl) { this.itemEl.style.display = 'none'; }
+                this.markOverlappingTasks(this.dragStartMinute, this.dragEndMinute, this.dragDate, this.itemType === 'task' ? this.itemId : null);
